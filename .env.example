BOT_TOKEN= # Discord bot token.
CHANNEL_ID= # Channel ID the bot should operate in.
WEBHOOK_ID= # Discord webhook ID
WEBHOOK_TOKEN= # Discord webhook token
PERMISSIONS_INTEGER=66560 # Permissions the bot should have.
CLIENT_ID= # Discord OAuth2 Client ID.
CLIENT_SECRET= # Discord OAuth2 Client Secret.
REDIRECT_URI= # Discord OAuth2 Redirect URI.
DISCORD_INVITE_URL= # Discord Invite URL to send to clients.
REDIS_HOST=redis # The hostname of the Redis service.
REDIS_PORT=6379 # The port on which Redis is running.
API_PORT=8080 # Port used for serving pages, api endpoints, and websocket connections.
SESSION_TTL_HOURS=24 # How long a user session is valid before they must re-authenticate.
RATE_LIMIT_API_MAX=100 # Max API calls per window
RATE_LIMIT_API_WINDOW_MS=60000 # API call window (1 minute)
RATE_LIMIT_ENV_MAX=10 # Max env changes per window
RATE_LIMIT_ENV_WINDOW_MS=300000 # Env change window (5 minutes)
RATE_LIMIT_LOGIN_MAX=5 # Max login attempts per window
RATE_LIMIT_LOGIN_WINDOW_MS=900000 # Login attempt window (15 minutes)
RATE_LIMIT_WS_CONNECTIONS=10 # Max WebSocket connections per IP
RATE_LIMIT_WS_MESSAGES=20 # Max WebSocket messages per second
RATE_LIMIT_WS_PAYLOAD=1048576 # Max WebSocket payload size in bytes (1MB)
UPLOAD_SIZE_LIMIT=26214400 # Max file upload size in bytes (25MB)
