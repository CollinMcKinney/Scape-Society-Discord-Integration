# Generate a ROOT user with random ID and Token at startup.
# store them in .env incase we want to access ROOT later.
ROOT_USER_ID=null
ROOT_SESSION_TOKEN=null

# Discord webooks (for sending messages to Discord)
WEBHOOK_ID=null
WEBHOOK_TOKEN=null

# Discord bot credentials
CHANNEL_ID=null
BOT_TOKEN=null
PERMISSIONS_INTEGER=66560

# Discord OAuth2 credentials
CLIENT_ID=null
CLIENT_SECRET=null
REDIRECT_URI=null

# Polling interval for fetching new messages from the server to send to Discord
POLL_INTERVAL=5000 # in milliseconds