# Node dependencies
node_modules/

# TypeScript
*.tsbuildinfo
dist/

# Yarn Berry / PnP (Zero Install)
# Commit PnP files
!.pnp.cjs
!.pnp.loader.mjs
!.pnp.*.cjs
!.pnp.*.mjs

# Yarn cache - commit for Zero Install (may contain multiple architectures)
!.yarn/cache/
!.yarn/releases/
!.yarn/sdks/
!.yarn/unplugged/

# State files - optional, can be committed for faster installs
!.yarn/build-state.yml
!.yarn/install-state.gz

# Ignore local yarn data
.yarn/data/

# Yarn lock (optional - commit if you want reproducible builds)
!yarn.lock

# Environment variables
*.env*
!.env.example

# backups
/data/backup.json

# VSCode settings
tasks.json
*.code-workspace

# Logs
*.log

# Keep TODO files etc. local-only;
# Create an issue on GitHub for public TODO's
*.md
!LICENSE.md
!README.md